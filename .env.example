# Database (Neon Postgres)
# Get this from the Neon dashboard (or Vercel Storage tab) -> Connection string.
# DIRECT_URL is the same host with "-pooler" removed - Prisma Migrate needs the unpooled connection.
# connection_limit is Prisma's own client-side pool size, not the pooler's total connections -
# keep it >1 or concurrent queries (e.g. Promise.all) will queue behind each other and time out.
DATABASE_URL="postgresql://[user]:[password]@ep-[id]-pooler.[region].aws.neon.tech/neondb?sslmode=require&channel_binding=require&pgbouncer=true&connection_limit=10"
DIRECT_URL="postgresql://[user]:[password]@ep-[id].[region].aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Auth.js v5
AUTH_SECRET="generate-with-npx-auth-secret"
NEXTAUTH_URL="http://localhost:3000"

# Paystack (TEST MODE)
PAYSTACK_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_xxx"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron (protects /api/cron/expire-orders from public calls)
CRON_SECRET="generate-a-random-string"

# Vercel Blob (admin product image uploads)
# Create a Blob store from the Vercel Storage tab, then copy its token.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"
